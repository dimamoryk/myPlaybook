pipeline {
    agent any

    environment {

        DATABASE_URL = "jdbc:postgresql://sql.otus.kartushin.su:5432/wishlist"
        DATABASE_USERNAME = credentials('postgres-username')
        DATABASE_PASSWORD = credentials('postgres-password')
        APPIUM_ANDROID_12_URL = "http://localhost:4723"
        APPIUM_ANDROID_14_URL = "http://localhost:4724"
    }

    parameters {
        string(name: 'DATABASE_USERNAME', defaultValue: '', description: 'Логин БД')
        string(name: 'DATABASE_PASSWORD', defaultValue: '', description: 'Пароль БД')
        choice(name: 'EMULATOR', choices: ['android-12', 'android-14'], description: 'Какой эмулятор использовать')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/dimamoryk/AutoTestWithMobileAppium.git',
                    credentialsId: 'github-credentials'
            }
        }

        stage('Start Docker Compose') {
            steps {
                script {

                    sh '''
                        docker-compose up -d
                        # Ждём, пока эмуляторы поднимутся (можно добавить проверку)
                        sleep 30
                    '''
                }
            }
        }

        stage('Run Mobile Tests') {
            steps {
                script {

                    def appiumPort = (params.EMULATOR == 'android-12') ? '4723' : '4724'
                    sh """
                        mvn clean test \
                            -DdatabaseUrl=${DATABASE_URL} \
                            -DdatabaseUsername=${params.DATABASE_USERNAME} \
                            -DdatabasePassword=${params.DATABASE_PASSWORD} \
                            -Dappium.port=${appiumPort}
                    """
                }
            }
        }

        stage('Publish Reports') {
            steps {
                publishHTML([
                    reportDir: 'target/surefire-reports',
                    reportFiles: '*.html',
                    reportName: 'Mobile Test Reports'
                ])
                junit 'target/surefire-reports/*.xml'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo 'Mobile tests failed!'
        }
        success {
            echo 'Mobile tests passed successfully!'
        }
    }
}