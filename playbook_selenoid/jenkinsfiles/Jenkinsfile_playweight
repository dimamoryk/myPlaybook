pipeline {
    agent any

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Ветка репозитория')
        string(name: 'BROWSER', defaultValue: 'chromium', description: 'Браузер: chromium/firefox/webkit')
        booleanParam(name: 'HEADLESS', defaultValue: true, description: 'Headless режим')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: "${params.BRANCH}",
                    url: 'https://github.com/dimamoryk/AutoTestWithPlayWright2.git',
                    credentialsId: 'github-credentials'
            }
        }
        stage('Run Playwright Tests') {
            steps {
                sh """
                    npm install
                    npx playwright install ${params.BROWSER}
                    npm test -- --project=${params.BROWSER} --headed=${!params.HEADLESS}
                """
            }
        }
    }
}